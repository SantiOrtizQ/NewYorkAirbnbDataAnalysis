				        {"host_name", type text}, {"neighbourhood_group", type text},
				        {"neighbourhood", type text}, {"latitude", type number},
				        {"longitude", type number}, {"room_type", type text},
				        {"price", Int64.Type}, {"minimum_nights", Int64.Type},
				        {"number_of_reviews", Int64.Type}, {"last_review", type date},
				        {"reviews_per_month", type number},
				        {"calculated_host_listings_count", Int64.Type},
				        {"availability_365", Int64.Type}
				    }),
				    #"Removed Errors" = Table.RemoveRowsWithErrors(#"Changed Types", {"id"}),
				    #"Filtered Nulls" = Table.SelectRows(#"Removed Errors", each [id] <> null),
				    DimNeighbourhood = let
				        S2 = Csv.Document(File.Contents("C:\Users\Santiago\OneDrive\Courses\PowerBICourse\AirbnbProjects\AB_NYC_2019.csv"),[Delimiter=",", Columns=16, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				        H2 = Table.PromoteHeaders(S2, [PromoteAllScalars=true]),
				        Sel = Table.SelectColumns(H2, {"neighbourhood", "neighbourhood_group"}),
				        Dedup = Table.Distinct(Sel, {"neighbourhood"}),
				        Sorted = Table.Sort(Dedup, {{"neighbourhood_group", Order.Ascending}, {"neighbourhood", Order.Ascending}}),
				        Idx = Table.AddIndexColumn(Sorted, "neighbourhood_id", 1, 1, Int64.Type)
				    in Idx,
				    DimRoomType = let
				        S3 = Csv.Document(File.Contents("C:\Users\Santiago\OneDrive\Courses\PowerBICourse\AirbnbProjects\AB_NYC_2019.csv"),[Delimiter=",", Columns=16, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				        H3 = Table.PromoteHeaders(S3, [PromoteAllScalars=true]),
				        Sel = Table.SelectColumns(H3, {"room_type"}),
				        Dedup = Table.Distinct(Sel),
				        Sorted = Table.Sort(Dedup, {{"room_type", Order.Ascending}}),
				        Idx = Table.AddIndexColumn(Sorted, "room_type_id", 1, 1, Int64.Type)
				    in Idx,
				    #"Merged Neighbourhood" = Table.NestedJoin(#"Filtered Nulls", {"neighbourhood"}, DimNeighbourhood, {"neighbourhood"}, "_nb", 0),
				    #"Expanded Neighbourhood" = Table.ExpandTableColumn(#"Merged Neighbourhood", "_nb", {"neighbourhood_id"}),
				    #"Merged RoomType" = Table.NestedJoin(#"Expanded Neighbourhood", {"room_type"}, DimRoomType, {"room_type"}, "_rt", 0),
				    #"Expanded RoomType" = Table.ExpandTableColumn(#"Merged RoomType", "_rt", {"room_type_id"}),
				    #"Selected Columns" = Table.SelectColumns(#"Expanded RoomType", {
				        "id", "name", "host_id", "neighbourhood_id", "room_type_id",
				        "latitude", "longitude", "price", "minimum_nights",
				        "number_of_reviews", "last_review", "reviews_per_month",
				        "calculated_host_listings_count", "availability_365"
				    }),
				    #"Renamed id" = Table.RenameColumns(#"Selected Columns", {{"id", "listing_id"}})
				in
